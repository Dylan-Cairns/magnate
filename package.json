{
  "name": "magnate",
  "private": true,
  "version": "1.0.0",
  "description": "Web-playable Magnate game with a competent computer opponent",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "bridge": "tsx src/bridge/cli.ts",
    "bot:eval": "tsx src/botEval/cli.ts",
    "benchmark:td-two-lane": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Mode full",
    "benchmark:td-two-lane:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Mode smoke",
    "benchmark:td-two-lane-search": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Benchmark search -Mode full -MinimumSpeedup 1.2",
    "benchmark:td-two-lane-search:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Benchmark search -Mode smoke -MinimumSpeedup 1.2",
    "benchmark:td-outer-shadow": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Benchmark outer-shadow -Mode full -MinimumSpeedup 1.2",
    "benchmark:td-outer-shadow:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_td_two_lane_browser_benchmark.ps1 -Benchmark outer-shadow -Mode smoke -MinimumSpeedup 1.2",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . && yarn typecheck",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "engines": {
    "node": "^22.12.0"
  },
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "dexie": "^4.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^5.1.4",
    "aislop": "^0.12.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "volta": {
    "node": "22.23.1",
    "yarn": "1.22.22"
  }
}
